// Landing page styles

.landing-main
  flex 1

// Hero Section
.hero
  padding $spacing-unit * 10 0
  text-align center
  background linear-gradient(180deg, $color-bg-light 0%, $color-bg 100%)

.hero-inner
  max-width $max-width-narrow
  margin 0 auto
  padding 0 $spacing-unit * 3

.hero-logo
  display flex
  align-items flex-start
  justify-content center
  gap $spacing-unit
  margin-bottom $spacing-unit * 3

.hero-logo-img
  max-width calc(100% - 40px)

.hero-cloud
  font-size 2.5rem
  font-weight 300
  color $color-primary
  line-height 1
  padding-top 30px

.hero-title
  font-size 1.5rem
  font-weight 400
  color $color-text
  margin-bottom $spacing-unit * 2

.hero-desc
  font-size 1.1rem
  color $color-text-light
  margin-bottom $spacing-unit * 4
  line-height 1.7

.hero-actions
  display flex
  justify-content center
  gap $spacing-unit * 2

.hero-cta
  display inline-flex
  align-items center
  padding $spacing-unit * 1.5 $spacing-unit * 4
  background $color-primary
  color #fff
  border-radius 6px
  font-size 1rem
  font-weight 500
  transition all 0.2s

  &:hover
    background $color-primary-dark
    color #fff
    text-decoration none

// Features Section
.features
  padding $spacing-unit * 8 0

.features-inner
  max-width $max-width
  margin 0 auto
  padding 0 $spacing-unit * 3

.section-title
  text-align center
  font-size 1.75rem
  margin-bottom $spacing-unit * 5
  color $color-text

.features-grid
  display grid
  grid-template-columns repeat(auto-fit, minmax(250px, 1fr))
  gap $spacing-unit * 3

.feature-card
  padding $spacing-unit * 3
  border 1px solid $color-border-light
  border-radius 8px
  transition all 0.2s

  &:hover
    border-color $color-primary
    box-shadow 0 4px 12px rgba(0, 136, 204, 0.1)

.feature-icon
  font-size 2rem
  margin-bottom $spacing-unit * 1.5

.feature-title
  font-size 1.1rem
  font-weight 600
  margin-bottom $spacing-unit
  color $color-text

.feature-desc
  font-size 0.9rem
  color $color-text-light
  line-height 1.6

@media (max-width: 640px)
  .hero
    padding $spacing-unit * 6 0

  .hero-cloud
    font-size 1.8rem

  .hero-title
    font-size 1.2rem

  .features-grid
    grid-template-columns 1fr
