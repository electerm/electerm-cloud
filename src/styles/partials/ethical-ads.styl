// EthicalAds styles
// Adapted from electerm.org/src/css/modern.styl

.ethical-ad-wrapper
  // Hidden by default; shown by JS (ethical-ad-active) only when loading EthicalAds
  display none
  position fixed
  bottom 0
  left 0
  right 0
  z-index 998
  min-height 56px
  align-items center
  justify-content center
  padding 8px 20px
  background $color-bg-light
  border-top 1px solid $color-border

  // When JS activates it, restore intended layout
  &.ethical-ad-active
    display flex

  // >= 1420px: corner card
  @media (min-width: 1420px)
    min-height auto
    bottom 24px
    left auto
    right 24px
    z-index 999
    padding 0
    border none
    max-width 300px
    background #fff
    border-radius 10px
    box-shadow 0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04)

    &.ethical-ad-active
      display block

// Reserve space so the fixed ad bar/card doesn't cover footer content.
// JS refines these to the actual rendered ad height (see ethical-ads partial script).
@media (max-width: 1419px)
  body
    padding-bottom 56px

@media (min-width: 1420px)
  .site-footer
    padding-bottom 80px

// Ad unit visibility — always visible; JS controls type/layout
.ethical-ad-unit
  display block

// Watermark logo in the reserved padding-bottom area (shown by JS when ad is visible)
.site-footer
  .watermark
    position absolute
    bottom var(--watermark-bottom, 0)
    left 0
    right 0
    height var(--watermark-height, 0)
    background-image url('https://electerm.org/electerm.png')
    background-position center
    background-size var(--watermark-bg-size, 160px) auto
    background-repeat no-repeat
    z-index 0
    opacity 0.03
    pointer-events none
