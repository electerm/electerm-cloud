// Static page styles (privacy, agreement)

.static-main
  flex 1
  padding $spacing-unit * 5 0

.static-inner
  max-width $max-width-narrow
  margin 0 auto
  padding 0 $spacing-unit * 3

.static-title
  font-size 2rem
  margin-bottom $spacing-unit
  color $color-text

.static-updated
  font-size 0.85rem
  color $color-text-lighter
  margin-bottom $spacing-unit * 4

.static-section
  margin-bottom $spacing-unit * 4

.static-section-title
  font-size 1.25rem
  font-weight 600
  margin-bottom $spacing-unit * 1.5
  color $color-text
  padding-bottom $spacing-unit
  border-bottom 1px solid $color-border-light

.static-section-body
  p
    color $color-text-light
    line-height 1.8
    margin-bottom $spacing-unit * 1.5
