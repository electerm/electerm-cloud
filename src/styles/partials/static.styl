// Static page styles (privacy, agreement)

.static-main
  flex 1
  padding $spacing-unit * 5 0

.static-inner
  max-width $max-width-narrow
  margin 0 auto
  padding 0 $spacing-unit * 3

.static-title
  font-size 2rem
  margin-bottom $spacing-unit
  color $color-text

.static-updated
  font-size 0.85rem
  color $color-text-lighter
  margin-bottom $spacing-unit * 4

.static-section
  margin-bottom $spacing-unit * 4

.static-section-title
  font-size 1.25rem
  font-weight 600
  margin-bottom $spacing-unit * 1.5
  color $color-text
  padding-bottom $spacing-unit
  border-bottom 1px solid $color-border-light

.static-section-body
  p
    color $color-text-light
    line-height 1.8
    margin-bottom $spacing-unit * 1.5

// 404 page styles

.not-found-main
  flex 1
  display flex
  align-items center
  justify-content center
  padding $spacing-unit * 6 0

.not-found-inner
  text-align center
  max-width $max-width-narrow
  margin 0 auto
  padding 0 $spacing-unit * 3

.not-found-code
  font-size 6rem
  font-weight 700
  color $color-primary
  line-height 1
  margin-bottom $spacing-unit * 3

.not-found-title
  font-size 1.75rem
  color $color-text
  margin-bottom $spacing-unit * 2

.not-found-desc
  font-size 1rem
  color $color-text-light
  margin-bottom $spacing-unit * 4

.not-found-link
  display inline-block
  padding $spacing-unit * 1.5 $spacing-unit * 4
  background $color-primary
  color #fff
  border-radius 4px
  font-size 1rem
  transition background 0.2s

  &:hover
    background $color-primary-dark
    color #fff
    text-decoration none
