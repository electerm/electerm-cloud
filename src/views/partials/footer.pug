// Footer partial
//- Expected variables: footerSections, siteMeta, lang, t (translate function)
footer.site-footer
  .footer-inner
    .footer-sections
      each section in footerSections
        .footer-section
          h4.footer-section-title= t(section.title)
          ul.footer-links
            each link in section.links
              li
                a(href=link.url target='_blank' rel='noopener noreferrer')= t(link.title)
    .footer-bottom
      .footer-copy= siteMeta.copyright
      .footer-legal
        - var privacyPath = lang === 'cn' ? '/zh-cn/privacy' : '/privacy'
        a(href=privacyPath)= lang === 'cn' ? '隐私政策' : 'Privacy Policy'
        span.footer-sep |
        - var agreementPath = lang === 'cn' ? '/zh-cn/agreement' : '/agreement'
        a(href=agreementPath)= lang === 'cn' ? '用户协议' : 'User Agreement'
