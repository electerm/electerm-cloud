#!/bin/bash
cd `dirname $0`
cd ../
rm -rf public
mkdir public

# Build React app bundles (app + admin)
echo "Building React bundles..."
npm run b2

# Build React app HTML pages (app + admin)
echo "Building React HTML pages..."
HOST=https://sync.electerm.org npm run b1

# Build static pages (landing, privacy, agreement) + CSS + sitemap
echo "Building static pages..."
npx tsx bin/build-static.js

echo "Build complete!"
